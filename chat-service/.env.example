# ── Conexões / segredos ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[senha]@db.[proj].supabase.co:5432/postgres
OPENAI_API_KEY=sk-...
# Deve bater com N8N_WEBHOOK_SECRET no frontend (Vercel). Vazio = endpoint aberto (dev).
WEBHOOK_SECRET=

# ── Modelos (custo) ──────────────────────────────────────────────────────────
# Foreground: conversa com o cliente + tool-calling. Modelo principal.
# NÃO use gpt-5.4-mini (quebra a extração de lead). gpt-5-mini é o validado.
CHAT_MODEL=gpt-5-mini

# Background: classificação de gap + resumo de interesse. Tarefas simples →
# modelo barato (roda com reasoning_effort=minimal no código). Rollback: gpt-5-mini.
BACKGROUND_MODEL=gpt-5-nano

# Extração de lead (nome/telefone) — o coração do SaaS. Mantido no mini: o A/B
# mostrou o nano perdendo nome (~89% recall < 98%). Só troque após validar com
# scripts/ab_lead_eval.py. Telefone/cep/email do nano ficaram 100%.
LEAD_MODEL=gpt-5-mini

# reasoning_effort do agente foreground. Vazio/ausente = default do modelo
# (comportamento atual). "low" corta ~43% do custo sem perder cards/lead no A/B
# (scripts/ab_foreground_broad.py) — ligar como piloto e monitorar lead/dia.
# NUNCA use "minimal" no foreground: alucina estoque.
FOREGROUND_REASONING_EFFORT=

# Embeddings da busca semântica de produtos.
EMBED_MODEL=text-embedding-3-small

# ── Comportamento ────────────────────────────────────────────────────────────
# Janela de buffer (segundos) pra agrupar mensagens seguidas do cliente.
BUFFER_WAIT_SECONDS=7
# Quantos produtos a busca vetorial retorna por consulta.
MATCH_COUNT=6
