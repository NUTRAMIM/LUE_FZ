    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output ?? '';\nlet parsed = { nome: null, telefone: null, email: null, cep: null };\ntry {\n  const cleaned = String(raw).replace(/^```json\\s*|\\s*```$/g, '').trim();\n  const obj = JSON.parse(cleaned);\n  parsed = {\n    nome: obj?.nome || null,\n    telefone: obj?.telefone || null,\n    email: obj?.email || null,\n    cep: obj?.cep || null,\n  };\n} catch (e) {}\nconst hasData = !!(parsed.nome || parsed.telefone || parsed.email || parsed.cep);\nreturn [{ json: {\n  ...parsed,\n  hasData,\n  conversation_id: $('Edit Fields').item.json.sessionId,\n  store_id: $('Edit Fields').item.json.store_id,\n} }];"
      },
